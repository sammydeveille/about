---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Sammy Deveille – Technical Lead">
  <main>
    <header class="hero">
      <h1>Sammy Deveille</h1>
      <p class="subtitle">Technical Lead</p>
      <p class="tagline">Experienced engineering leader with expertise in scaling teams, optimizing processes, and driving digital transformation. Proven success in cloud infrastructure, Agile methodologies, and security compliance. Skilled in leading multi-disciplinary teams and aligning engineering efforts with business goals.</p>
      <nav class="social-links">
        <a href="https://www.linkedin.com/in/sammydeveille/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://github.com/SammyDeveilleASP" target="_blank" rel="noopener" aria-label="GitHub (Professional)">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </a>
        <a href="https://github.com/SammyDeveille" target="_blank" rel="noopener" aria-label="GitHub (Personal)" class="icon-personal">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a href="mailto:sammydeveille@gmail.com" aria-label="Email">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
        </a>
      </nav>
    </header>

    <section id="experience">
      <h2>Experience</h2>

      <article class="role">
        <div class="role-header">
          <div class="role-left">
            <img src={`${base}logos/asp.png`} alt="ASP Events" class="role-logo" />
            <div class="role-info">
              <span class="role-title">Technical Lead</span>
              <h3>ASP Events</h3>
              <p class="role-desc">Event website provider</p>
            </div>
          </div>
          <div class="role-right">
            <span>Mar 2024 – Present</span>
            <span>Event Tech</span>
            <span>London</span>
          </div>
        </div>

        <h4>Infrastructure & Cost</h4>
        <ul>
          <li>Deployed WAF firewall strategies for traffic filtering and threat protection</li>
          <li>Dockerised application layer for portability and consistency</li>
          <li>Implemented CI/CD pipelines with integrated security scanning, vulnerability tracking and automated deployment</li>
          <li>Optimized infrastructure spend, yielding annual savings</li>
        </ul>

        <h4>Delivery & Quality</h4>
        <ul>
          <li>Transitioned legacy ColdFusion solution to Lucee open source</li>
          <li>Video compression pipeline for performance and cost reduction</li>
          <li>Refactored redundant code and improved automated test coverage</li>
          <li>Stress and load testing for performance benchmarking and optimisation</li>
        </ul>

        <h4>Team & Culture</h4>
        <ul>
          <li>Transitioned team to adopt TDD and documentation-first practices for continuous improvement</li>
          <li>Mentored team, fostering skill growth and knowledge sharing</li>
        </ul>

        <div class="tech-badges">
          <span data-tech="react">React</span><span data-tech="nodejs">NodeJS</span><span data-tech="nodejs">Lucee</span><span data-tech="aws">AWS</span><span data-tech="ansible">Ansible</span><span data-tech="terraform">Terraform</span><span data-tech="grafana">Grafana</span><span data-tech="grafana">Prometheus</span>
        </div>
      </article>

      <article class="role">
        <div class="role-header">
          <div class="role-left">
            <img src={`${base}logos/springpod.png`} alt="Springpod" class="role-logo" />
            <div class="role-info">
              <span class="role-title">Head of Engineering</span>
              <h3>Springpod</h3>
              <p class="role-desc">Career guidance e-learning for students</p>
            </div>
          </div>
          <div class="role-right">
            <span>Apr 2023 – Jan 2024</span>
            <span>eLearning</span>
            <span>London</span>
          </div>
        </div>
        <h4>Delivery</h4>
        <ul>
          <li>Product feature implementation including content delivery, identity federation, maintenance and support</li>
          <li>Architected SSO identity federation for UCAS partnership"</li>
        </ul>

        <h4>Team & Culture</h4>
        <ul>
          <li>Introduced Scrum in a team of 6 to align effort with company strategy</li>
          <li>Streamlined documentation and processes across teams</li>
        </ul>
        <div class="tech-badges">
          <span data-tech="nodejs">NodeJS</span><span data-tech="graphql">GraphQL</span><span data-tech="react">React</span><span data-tech="nextjs">Next.JS</span><span data-tech="aws">AWS</span><span data-tech="docker">Docker</span><span data-tech="kubernetes">K8S</span><span data-tech="grpc">gRPC</span><span data-tech="algolia">Algolia</span>
        </div>
      </article>

      <article class="role">
        <div class="role-header">
          <div class="role-left">
            <img src={`${base}logos/glisser.png`} alt="Glisser" class="role-logo" />
            <div class="role-info">
              <span class="role-title">Chief Technology Officer</span>
              <h3>Glisser</h3>
              <p class="role-desc">Real-time interaction platform for live and virtual events</p>
            </div>
          </div>
          <div class="role-right">
            <span>Apr 2015 – Jan 2023</span>
            <span>Event Tech</span>
            <span>London</span>
          </div>
        </div>

        <h4>Strategy & Growth</h4>
        <ul>
          <li>Joined as employee #3, built prototype into market-ready product through various seeds, securing Big Four clients</li>
          <li>Defined and executed technology roadmap from early prototype to enterprise-grade platform, including COVID-era pivot to virtual/hybrid</li>
        </ul>

        <h4>Architecture & Scale</h4>
        <ul>
          <li>Engineered platform for multi-million concurrent WebSocket connections</li>
          <li>Migrated cloud infrastructure for cost and performance</li>
          <li>Designed real-time messaging layer for polling, Q&A, slide sync and analytics</li>
        </ul>

        <h4>Team & Culture</h4>
        <ul>
          <li>Scaled engineering from 2 to 10 (company to 30+), shaping hiring, onboarding and mentoring engineers through to senior/lead roles</li>
        </ul>

        <h4>Security & Compliance</h4>
        <ul>
          <li>Led ISO 27001 certification and GDPR compliance</li>
          <li>Enforced OWASP standards with continuous security assessments toward SOC 2 compliance</li>
        </ul>

        <h4>DevOps & Infrastructure</h4>
        <ul>
          <li>Infrastructure as Code with Terraform</li>
          <li>Containerized services with Docker, CI/CD pipelines</li>
          <li>Observability stack (ELK, monitoring, alerting)</li>
        </ul>

        <div class="tech-badges">
          <span data-tech="react">React</span><span data-tech="angular">Angular</span><span data-tech="nodejs">NodeJS</span><span data-tech="dotnet">.NET</span><span data-tech="php">PHP</span><span data-tech="python">Python</span><span data-tech="websocket">WebSocket</span><span data-tech="mysql">MySQL</span><span data-tech="redis">Redis</span>
        </div>
        <div class="tech-badges">
          <span data-tech="aws">AWS</span><span data-tech="azure">Azure</span><span data-tech="docker">Docker</span><span data-tech="rabbitmq">RabbitMQ</span><span data-tech="elk">ELK</span>
        </div>
      </article>

      <article class="role">
        <div class="role-header">
          <div class="role-left">
            <img src={`${base}logos/good-elearning.png`} alt="Good eLearning" class="role-logo" />
            <div class="role-info">
              <span class="role-title">Web Developer</span>
              <h3>Good eLearning</h3>
              <p class="role-desc">Accredited business and enterprise architecture courses (ITIL, TOGAF, Prince2)</p>
            </div>
          </div>
          <div class="role-right">
            <span>Jul 2013 – Apr 2015</span>
            <span>eLearning</span>
            <span>London</span>
          </div>
        </div>
        <ul>
          <li>Led development and rollout of a bespoke LMS in Angular & .NET, reporting directly to the CTO</li>
          <li>Content tracking (SCORM), organisational user management, CMS and reporting (HTML5, PDF, Excel)</li>
          <li>Dashboard and analytics visualisation</li>
          <li>Enforced TDD practices across the full stack, achieving 90% unit test coverage</li>
        </ul>
        <div class="tech-badges">
          <span data-tech="dotnet">.NET</span><span data-tech="dotnet">EF</span><span data-tech="angular">AngularJS</span><span data-tech="sql">SQL</span><span data-tech="nunit">NUnit</span><span data-tech="azure">Azure</span>
        </div>
      </article>

      <article class="role">
        <div class="role-header">
          <div class="role-left">
            <img src={`${base}logos/equisys.png`} alt="Equisys" class="role-logo" />
            <div class="role-info">
              <span class="role-title">Software Developer</span>
              <h3>Equisys</h3>
              <p class="role-desc">Document and expense software</p>
            </div>
          </div>
          <div class="role-right">
            <span>Jun 2010 – Jul 2013</span>
            <span>Office ERP</span>
            <span>London</span>
          </div>
        </div>
        <ul>
          <li>Full development lifecycle of ERP software in .NET and C++ for desktop and web applications in a team of 8, reporting to senior leads and CTO</li>
          <li>Integration with Microsoft Office, SharePoint, Dynamics NAV, PDF and fax processing</li>
        </ul>
        <div class="tech-badges">
          <span data-tech="dotnet">.NET</span><span data-tech="cpp">C++</span><span data-tech="microsoft">MS Office</span><span data-tech="dotnet">Dynamics NAV</span><span data-tech="azure">Azure</span>
        </div>
      </article>

      <article class="role">
        <div class="role-header">
          <div class="role-left">
            <img src={`${base}logos/iminds.png`} alt="iMinds" class="role-logo" />
            <div class="role-info">
              <span class="role-title">Research Software Engineer</span>
              <h3>iMinds</h3>
              <p class="role-desc">MobiThin: European research project bringing industry partners together around thin client architecture</p>
            </div>
          </div>
          <div class="role-right">
            <span>Oct 2008 – Jun 2010</span>
            <span>Research</span>
            <span>Ghent, Belgium</span>
          </div>
        </div>
        <ul>
          <li>Remote desktop protocol and network/bandwidth optimization</li>
          <li>Implementation of network tools for monitoring and load testing in C++</li>
          <li>Test execution scripting in Bash</li>
        </ul>
        <div class="tech-badges">
          <span data-tech="cpp">C++</span><span data-tech="unix">RFB</span><span data-tech="unix">Bash</span><span data-tech="perl">Perl</span><span data-tech="grafana">Zabbix</span>
        </div>
      </article>
    </section>

    <section id="skills">
      <h2>Skills</h2>

      <div class="two-col">
        <div class="col">
          <h3 class="col-title">Leadership</h3>

          <div class="skills-section">
            <h4>Strategy & Vision</h4>
            <p>Owned technical roadmaps from early-stage prototype through enterprise scale. Led architecture decisions across cloud migrations, platform pivots and compliance programs.</p>
          </div>
          <div class="skills-section">
            <h4>People & Growth</h4>
            <p>Scaled teams from 2 to 10+, shaped hiring pipelines, and mentored engineers through to senior/lead roles. Built cross-functional collaboration across product, design and engineering.</p>
          </div>
          <div class="skills-section">
            <h4>Process & Delivery</h4>
            <p>Introduced Agile, TDD and documentation-first practices. Balanced short-term delivery with long-term architectural investment. Track engineering effectiveness through DORA metrics.</p>
          </div>
          <div class="skills-section">
            <h4>Governance & Compliance</h4>
            <p>Led ISO 27001, GDPR and Cyber Essentials accreditation. Security-first mindset: least privilege by default, continuous assessment, risk-minimised architecture.</p>
          </div>
          <div class="skills-section">
            <h4>Culture & Mindset</h4>
            <p>Cultivated "no blame" environments that encourage experimentation, continuous learning and knowledge sharing. Data-driven decision-making to align engineering effort with business outcomes.</p>
          </div>
        </div>

        <div class="col">
          <h3 class="col-title">Technical</h3>

          <div class="skills-section">
            <h4>Cloud & IaC</h4>
            <p>AWS · Azure · Docker · K8S · Helm · Ansible · CloudFormation · Terraform</p>
          </div>

          <div class="skills-section">
            <h4>Application Development</h4>
            <p>NodeJS · TypeScript · NestJS · React · Angular · Next.JS · Python · .NET · C++ · Java</p>
          </div>

          <div class="skills-section">
            <h4>APIs</h4>
            <p>REST · GraphQL · WebSocket · gRPC</p>
          </div>

          <div class="skills-section">
            <h4>Data & Storage</h4>
            <p>MySQL · PostgreSQL · InfluxDB · Redis · S3</p>
          </div>

          <div class="skills-section">
            <h4>CI/CD & Security</h4>
            <p>GitHub Actions · Jenkins · CodeBuild · Trivy · OWASP ZAP · DefectDojo</p>
          </div>

          <div class="skills-section">
            <h4>Observability</h4>
            <p>CloudWatch · Grafana · Prometheus · NewRelic · Zabbix</p>
          </div>

          <div class="skills-section">
            <h4>Testing</h4>
            <p>Mocha · Playwright · Supertest · K6 · Jest · NUnit</p>
          </div>

          <div class="skills-section">
            <h4>Integration</h4>
            <p>Okta · OneLogin · Office365 · Stripe · SalesForce · HubSpot · Zapier · Mapbox · Jitsi</p>
          </div>

          <div class="skills-section">
            <h4>AI / LLM</h4>
            <p>OpenRouter · LM Studio · LangChain</p>
          </div>
        </div>
      </div>
    </section>

    <section id="projects">
      <h2>Personal Projects</h2>

      <article class="role">
        <div class="role-header">
          <div class="role-left">
            <a href="https://github.com/sammydeveille/mapbox-sandbox" target="_blank" rel="noopener" aria-label="mapbox-sandbox on GitHub" class="project-link"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg></a>
            <div class="role-info">
              <h3>mapbox-sandbox</h3>
              <p class="role-desc">Interactive map rendering of spatial and time-series data</p>
            </div>
          </div>
        </div>
        <div class="tech-badges">
          <span data-tech="mapbox">Mapbox</span><span data-tech="nextjs">Next.js</span><span data-tech="sql">PostgreSQL</span><span data-tech="elk">Elasticsearch</span><span data-tech="docker">Docker</span>
        </div>
      </article>

      <article class="role">
        <div class="role-header">
          <div class="role-left">
            <a href="https://github.com/sammydeveille/cyber-bench" target="_blank" rel="noopener" aria-label="cyber-bench on GitHub" class="project-link"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg></a>
