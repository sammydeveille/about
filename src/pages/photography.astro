];
---

<Layout title="Sammy Deveille – Photography">
  <main>
    <header class="hero">
      <div class="hero-top">
        <div class="hero-left">
          <h1>Sammy Deveille</h1>
          <p class="subtitle">Photography</p>
        </div>
        <nav class="site-nav">
          <a href={`${base}`}>Dev</a>
          <a href={`${base}music`}>Music</a>
          <a href={`${base}photography`} class="active">Photo</a>
        </nav>
      </div>
      <nav class="social-links">
        <a href="https://500px.com/p/SammyDeveille" target="_blank" rel="noopener" aria-label="500px">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </a>
      </nav>
    </header>

    <section id="gallery">
      <h2>Gallery</h2>
      <div class="photo-grid">
        {photos.map((photo) => (
          <a href={photo.url} target="_blank" rel="noopener" class="photo-tile" title={photo.title}>
            <img
              src={`https://drscdn.500px.org/photo/${photo.id}/q%3D80_m%3D600/v2`}
              alt={photo.title}
              loading="lazy"
            />
            <span class="photo-title">{photo.title}</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.75rem;
  }

  .photo-tile {
    position: relative;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: border-color 0.2s, transform 0.2s;
    display: block;
  }

  .photo-tile:hover {
    border-color: var(--color-accent);
    transform: scale(1.02);
    opacity: 1;
  }

  .photo-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.5rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 500;
    color: #fff;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    opacity: 0;
    transition: opacity 0.2s;
  }

  .photo-tile:hover .photo-title {
    opacity: 1;
  }

  @media (max-width: 600px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
