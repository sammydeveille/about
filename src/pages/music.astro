---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const tracks = [
  { title: 'Bright Curse – What\'s Beyond the Sun', type: 'soundcloud', url: 'https://soundcloud.com/sammybass/bright-curse-whats-beyond-the-sun', artwork: '' },
  { title: 'Yoko – Hallelujah Michi', type: 'soundcloud', url: 'https://soundcloud.com/sammybass/yoko-hallelujah-michi', artwork: '' },
  { title: 'The Fraziers – Whatever', type: 'soundcloud', url: 'https://soundcloud.com/sammybass/the-fraziers-whatever', artwork: '' },
  { title: 'Hungry Ghosts', type: 'soundcloud', url: 'https://soundcloud.com/sammybass/hungry-ghosts', artwork: '' },
  { title: 'Fraziers – Bass Sample', type: 'soundcloud', url: 'https://soundcloud.com/sammybass/fraziers-bass-sample', artwork: '' },
  { title: 'Twist of Soul – Miami Night', type: 'soundcloud', url: 'https://soundcloud.com/sammybass/twist-of-soul-miami-night', artwork: '' },
  { title: 'Twist of Soul – Better Life', type: 'soundcloud', url: 'https://soundcloud.com/sammybass/twist-of-soul-better-life', artwork: '' },
];
---

<Layout title="Sammy Deveille – Music">
  <main>
    <header class="hero">
      <div class="hero-top">
        <div class="hero-left">
          <h1>Sammy Deveille</h1>
          <p class="subtitle">Music</p>
        </div>
        <nav class="site-nav">
          <a href={`${base}`}>Dev</a>
          <a href={`${base}music`} class="active">Music</a>
          <a href={`${base}photography`}>Photo</a>
        </nav>
      </div>
      <nav class="social-links">
        <a href="https://soundcloud.com/sammybass" target="_blank" rel="noopener" aria-label="SoundCloud">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        </a>
      </nav>
    </header>

    <section id="tracks">
      <h2>Tracks</h2>
      <div class="track-grid">
        {tracks.map((track, i) => (
          <button class="track-tile" data-index={i} aria-expanded="false" aria-label={`Play ${track.title}`}>
            {track.artwork ? (
              <img src={track.artwork} alt={track.title} class="track-artwork" />
            ) : (
              <div class="track-artwork-placeholder">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
              </div>
            )}
            <span class="track-title">{track.title}</span>
          </button>
        ))}
      </div>

      <div class="player-panel" id="player-panel" hidden>
        <button class="player-close" id="player-close" aria-label="Close player">&times;</button>
        <div class="player-content" id="player-content"></div>
      </div>
    </section>
  </main>
</Layout>

<script define:vars={{ tracks }}>
  const tiles = document.querySelectorAll('.track-tile');
  const panel = document.getElementById('player-panel');
  const content = document.getElementById('player-content');
  const closeBtn = document.getElementById('player-close');

  function openTrack(index) {
    const track = tracks[index];
    let embed = '';

    if (track.type === 'soundcloud') {
      embed = `<iframe width="100%" height="166" scrolling="no" frameborder="no" allow="autoplay" src="https://w.soundcloud.com/player/?url=${encodeURIComponent(track.url)}&color=%236cb4ee&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false" title="${track.title}"></iframe>`;
    } else if (track.type === 'spotify') {
      embed = `<iframe src="${track.url}" width="100%" height="152" frameborder="0" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" title="${track.title}"></iframe>`;
    } else if (track.type === 'youtube') {
      embed = `<iframe width="100%" height="315" src="${track.url}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen title="${track.title}"></iframe>`;
    }

    content.innerHTML = embed;
    panel.hidden = false;

    tiles.forEach(t => t.classList.remove('active'));
    tiles[index].classList.add('active');
    tiles[index].setAttribute('aria-expanded', 'true');
  }

  function closePlayer() {
    panel.hidden = true;
    content.innerHTML = '';
    tiles.forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-expanded', 'false');
    });
  }

  tiles.forEach(tile => {
    tile.addEventListener('click', () => {
      const index = parseInt(tile.dataset.index);
      if (tile.classList.contains('active')) {
        closePlayer();
      } else {
        openTrack(index);
      }
    });
  });

  closeBtn.addEventListener('click', closePlayer);
</script>

<style>
  .track-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.75rem;
  }

  .track-tile {
    position: relative;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    cursor: pointer;
    transition: border-color 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .track-tile:hover {
    border-color: var(--color-accent);
    transform: scale(1.02);
  }

  .track-tile.active {
    border-color: var(--color-accent);
  }

  .track-artwork {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .track-artwork-placeholder {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }

  .track-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.5rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 500;
    color: #fff;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    opacity: 0;
    transition: opacity 0.2s;
  }

  .track-tile:hover .track-title {
    opacity: 1;
  }

  .player-panel {
    margin-top: 1.5rem;
    padding: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    position: relative;
  }

  .player-close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s;
  }

  .player-close:hover {
    color: var(--color-text);
  }

  .player-content iframe {
    display: block;
    border-radius: 4px;
  }

  @media (max-width: 600px) {
    .track-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
